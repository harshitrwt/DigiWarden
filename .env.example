# Backend (FastAPI)
# If you run from `DigiPatron/backend`, defaults already work.
STORAGE_PATH=./data
# For Windows absolute paths, use forward slashes, e.g. sqlite:///C:/path/to/contentgenome.db
DB_URL=sqlite:///./data/contentgenome.db

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api

